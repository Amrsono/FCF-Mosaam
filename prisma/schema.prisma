generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id              String       @id @default(uuid())
  phone           String       @unique
  name            String
  email           String?
  address         String?
  tier            String       @default("New")
  deliveries      Int          @default(0) // Jumia deliveries
  bostaDeliveries Int          @default(0) // Bosta deliveries
  createdAt       DateTime     @default(now())

  orders          Order[]
  bostaOrders     BostaOrder[]
}

model Order {
  id            String    @id
  customerPhone String
  description   String
  totalValue    Float     // Using Float for typical DB precision without needing Decimal.js locally 
  category      String
  status             String    @default("Inventory") // "Inventory", "Picked_Up", "Returned", "Cancelled"
  receivedAt         DateTime  @default(now())
  pickedUpAt         DateTime?
  returnedAt         DateTime?

  // New fields for detailed inventory reporting
  outlet             String    @default("eltalg")
  size               String    @default("M")
  paymentMethod      String    @default("Cash")
  orderCost          Float     @default(0)

  // Cancellation and Deletion tracking
  cancellationReason String?
  isDeleted          Boolean   @default(false)
  deletionReason     String?

  customer      Customer  @relation(fields: [customerPhone], references: [phone])
}

model BasataTransaction {
  id              String   @id @default(uuid())
  category        String   // "Mobile", "Internet", "Utilities", "Government", "Other"
  serviceProvider String   // e.g. "Vodafone Top-up", "WE ADSL", "Electricity NFC"
  amount          Float
  transactionId   String?  // The POS Transaction ID
  paymentMethod   String   @default("Cash") // Cash, Card, etc.
  percentage      Float    @default(0) // Commission or Fee percentage
  referenceNumber String?  // Keep for backward compatibility or legacy
  performedAt     DateTime @default(now())
}

model BostaOrder {
  id            String    @id
  customerPhone String
  description   String
  totalValue    Float     
  category      String
  status             String    @default("Inventory") // "Inventory", "Picked Up", "Returned", "Cancelled"
  receivedAt         DateTime  @default(now())
  pickedUpAt         DateTime?
  returnedAt         DateTime?

  // New fields for detailed inventory reporting
  outlet             String    @default("eltalg")
  size               String    @default("M")
  paymentMethod      String    @default("Cash")
  orderCost          Float     @default(0)

  // Cancellation and Deletion tracking
  cancellationReason String?
  isDeleted          Boolean   @default(false)
  deletionReason     String?

  customer           Customer  @relation(fields: [customerPhone], references: [phone])
}

model Admin {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  role         String   @default("staff") // "admin" | "staff"
  createdAt    DateTime @default(now())
}

model UserLog {
  id        String   @id @default(uuid())
  username  String
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model CustomerReturn {
  id            String    @id @default(uuid())
  orderId       String?   // Optional link to the original Jumia order
  customerPhone String
  customerName  String    @default("Unknown")
  description   String
  reason        String?
  outlet        String    @default("eltalg") // Which branch received the return
  status        String    @default("At Station") // "At Station" | "Returned to Jumia"
  receivedAt    DateTime  @default(now())
  returnedAt    DateTime? // When marked as returned to Jumia
}

model CallLog {
  id            String    @id @default(uuid())
  orderId       String                          // The Jumia or Bosta order ID
  orderSource   String    @default("jumia")     // "jumia" | "bosta"
  customerPhone String
  agentName     String?                         // Username who took ownership
  takenAt       DateTime?                       // When agent clicked "Take Call"
  resolution    String?                         // "coming_pickup" | "will_cancel" | "no_answer" | "declined" | "no_longer_wants"
  notes         String?
  resolvedAt    DateTime?
  isClosed      Boolean   @default(false)
  createdAt     DateTime  @default(now())
}

